# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local IDE / AI config
opencode.json
CLAUDE.md
AGENTS.md

# Tesseract OCR training data (downloaded at runtime)
eng.traineddata
tel.traineddata

# test scripts (not for production)
test-pdf.mjs
test-pdf2.mjs

# consolidated SQL exports (migrations in supabase/migrations/ are canonical)
/supabase-migration.sql
/supabase-storage.sql

# default Next.js starter assets (not used)
/public/next.svg
/public/vercel.svg
/public/file.svg
/public/window.svg

# draft proxy middleware (superseded by root proxy.ts)
/src/proxy.ts
